# Google AI API key (used for Gemini LLM)
GOOGLE_API_KEY=your_google_api_key

# Deepgram API key (used for STT and TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Roboflow credentials (API key needed to download model weights for local inference)
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_API_URL=https://serverless.roboflow.com

# Stream Video credentials (used for edge transport)
STREAM_API_KEY=your_stream_key
STREAM_API_SECRET=your_stream_secret
